[Unit]
Description=MJPG Streamer for myCobot 280 Pi USB Camera
After=network.target

[Service]
Type=simple
User=er
ExecStart=/usr/local/bin/mjpg_streamer -i "input_uvc.so -r 640x480 -d /dev/video0 -f 30" -o "output_http.so -p 8080 -w /usr/local/share/mjpg-streamer/www"
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
