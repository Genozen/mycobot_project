<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mycobot_280pi">

  <xacro:property name="mesh_path" value="package://mycobot_description/meshes"/>
  <xacro:property name="gripper_mesh" value="package://mycobot_description/meshes/adaptive_gripper"/>

  <!-- Dummy inertial macro (required for Gazebo/MoveIt2) -->
  <xacro:macro name="default_inertial" params="mass:=0.1">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </xacro:macro>

  <!-- Set to true when the robot is physically mounted upside-down -->
  <xacro:arg name="flipped" default="true"/>
  <!-- Set to false to hide the gripper mesh for debugging -->
  <xacro:arg name="show_gripper" default="true"/>

  <!-- ==================== Links ==================== -->

  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <xacro:if value="$(arg flipped)">
      <origin xyz="0 0 0" rpy="3.14159 0 0"/>
    </xacro:if>
    <xacro:unless value="$(arg flipped)">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:unless>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/G_base.dae"/>
      </geometry>
      <origin xyz="0 0 -0.03" rpy="0 0 1.5708"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/G_base.dae"/>
      </geometry>
      <origin xyz="0 0 -0.03" rpy="0 0 1.5708"/>
    </collision>
    <xacro:default_inertial mass="0.5"/>
  </link>

  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/joint1_pi.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/joint1_pi.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial/>
  </link>

  <link name="link2">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/joint2.dae"/>
      </geometry>
      <origin xyz="0 0 -0.06096" rpy="0 0 -1.5708"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/joint2.dae"/>
      </geometry>
      <origin xyz="0 0 -0.06096" rpy="0 0 -1.5708"/>
    </collision>
    <xacro:default_inertial/>
  </link>

  <link name="link3">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/joint3.dae"/>
      </geometry>
      <origin xyz="0 0 0.03256" rpy="0 -1.5708 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/joint3.dae"/>
      </geometry>
      <origin xyz="0 0 0.03256" rpy="0 -1.5708 0"/>
    </collision>
    <xacro:default_inertial/>
  </link>

  <link name="link4">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/joint4.dae"/>
      </geometry>
      <origin xyz="0 0 0.03056" rpy="0 -1.5708 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/joint4.dae"/>
      </geometry>
      <origin xyz="0 0 0.03056" rpy="0 -1.5708 0"/>
    </collision>
    <xacro:default_inertial/>
  </link>

  <link name="link5">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/joint5.dae"/>
      </geometry>
      <origin xyz="0 -0.001 -0.0345" rpy="0 -1.5708 1.5708"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/joint5.dae"/>
      </geometry>
      <origin xyz="0 -0.001 -0.0345" rpy="0 -1.5708 1.5708"/>
    </collision>
    <xacro:default_inertial/>
  </link>

  <link name="link6">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/joint6.dae"/>
      </geometry>
      <origin xyz="0 0 -0.038" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/joint6.dae"/>
      </geometry>
      <origin xyz="0 0 -0.038" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial/>
  </link>

  <link name="link6_flange">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/joint7.dae"/>
      </geometry>
      <origin xyz="0 0 -0.012" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="${mesh_path}/joint7.dae"/>
      </geometry>
      <origin xyz="0 0 -0.012" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.05"/>
  </link>

  <!-- ==================== Camera Flange ==================== -->

  <link name="camera_flange">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/camera_flange.dae"/>
      </geometry>
      <origin xyz="0.024 -0.008 0.0" rpy="0 3.14159 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
      <origin xyz="0.0 0.0 0.015" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.03"/>
  </link>

  <link name="camera_link"/>

  <!-- ==================== Adaptive Gripper ==================== -->
  <xacro:if value="$(arg show_gripper)">

  <link name="gripper_base">
    <visual>
      <geometry>
        <mesh filename="${gripper_mesh}/gripper_base.dae"/>
      </geometry>
      <origin xyz="0.0 0 -0.012" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.02 0.025"/>
      </geometry>
      <origin xyz="0.0 0.01 0.0" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.05"/>
  </link>

  <link name="gripper_left1">
    <visual>
      <geometry>
        <mesh filename="${gripper_mesh}/gripper_left1.dae"/>
      </geometry>
      <origin xyz="0.039 -0.0133 -0.012" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.015 0.04 0.01"/>
      </geometry>
      <origin xyz="0.02 0.0 0.0" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.01"/>
  </link>

  <link name="gripper_left2">
    <visual>
      <geometry>
        <mesh filename="${gripper_mesh}/gripper_left2.dae"/>
      </geometry>
      <origin xyz="0.005 -0.0195 -0.012" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.015 0.03 0.01"/>
      </geometry>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.01"/>
  </link>

  <link name="gripper_left3">
    <visual>
      <geometry>
        <mesh filename="${gripper_mesh}/gripper_left3.dae"/>
      </geometry>
      <origin xyz="0.012 0.0025 -0.012" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.015 0.02 0.01"/>
      </geometry>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.01"/>
  </link>

  <link name="gripper_right1">
    <visual>
      <geometry>
        <mesh filename="${gripper_mesh}/gripper_right1.dae"/>
      </geometry>
      <origin xyz="-0.039 -0.0133 -0.012" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.015 0.04 0.01"/>
      </geometry>
      <origin xyz="-0.02 0.0 0.0" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.01"/>
  </link>

  <link name="gripper_right2">
    <visual>
      <geometry>
        <mesh filename="${gripper_mesh}/gripper_right2.dae"/>
      </geometry>
      <origin xyz="-0.005 -0.0195 -0.012" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.015 0.03 0.01"/>
      </geometry>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.01"/>
  </link>

  <link name="gripper_right3">
    <visual>
      <geometry>
        <mesh filename="${gripper_mesh}/gripper_right3.dae"/>
      </geometry>
      <origin xyz="-0.012 0.0025 -0.012" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.015 0.02 0.01"/>
      </geometry>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    </collision>
    <xacro:default_inertial mass="0.01"/>
  </link>

  </xacro:if>

  <!-- ==================== Joints ==================== -->

  <joint name="virtual_joint" type="fixed">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint1" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.9321" upper="2.9321" velocity="3.14"/>
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.13956" rpy="0 0 0"/>
  </joint>

  <joint name="joint2" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.4434" upper="2.4434" velocity="3.14"/>
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 -0.001" rpy="0 1.5708 -1.5708"/>
  </joint>

  <joint name="joint3" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.6179" upper="2.6179" velocity="3.14"/>
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="-0.1104 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint4" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.6179" upper="2.6179" velocity="3.14"/>
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="-0.096 0 0.06462" rpy="0 0 -1.5708"/>
  </joint>

  <joint name="joint5" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.7052" upper="2.7925" velocity="3.14"/>
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 -0.07318 -0.001" rpy="1.5708 -1.5708 0"/>
  </joint>

  <joint name="joint6" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-3.14159" upper="3.14159" velocity="3.14"/>
    <parent link="link6"/>
    <child link="link6_flange"/>
    <origin xyz="0 0.0456 0" rpy="-1.5708 0 0"/>
  </joint>

  <!-- Camera flange bracket attaches to the arm flange (rotated 45° CCW) -->
  <joint name="flange_to_camera_flange" type="fixed">
    <parent link="link6_flange"/>
    <child link="camera_flange"/>
    <origin xyz="0 0 0.01" rpy="1.579 0 -0.7854"/>
  </joint>

  <!-- Camera optical frame on the camera flange bracket -->
  <joint name="camera_flange_to_camera" type="fixed">
    <parent link="camera_flange"/>
    <child link="camera_link"/>
    <origin xyz="0.03 0 0.04" rpy="0 1.5708 0"/>
  </joint>

  <xacro:if value="$(arg show_gripper)">

  <!-- Gripper base stacked after camera along +Y, rotated 90° CW -->
  <joint name="camera_flange_to_gripper" type="fixed">
    <parent link="camera_flange"/>
    <child link="gripper_base"/>
    <origin xyz="0 0.065 0" rpy="0 -1.5708 0"/>
  </joint>

  <!-- Gripper finger joints (fixed — visual only, controlled via pymycobot) -->
  <joint name="gripper_controller" type="fixed">
    <parent link="gripper_base"/>
    <child link="gripper_left3"/>
    <origin xyz="-0.012 0.005 0" rpy="0 0 0"/>
  </joint>

  <joint name="gripper_base_to_gripper_left2" type="fixed">
    <parent link="gripper_base"/>
    <child link="gripper_left2"/>
    <origin xyz="-0.005 0.027 0" rpy="0 0 0"/>
  </joint>

  <joint name="gripper_left3_to_gripper_left1" type="fixed">
    <parent link="gripper_left3"/>
    <child link="gripper_left1"/>
    <origin xyz="-0.027 0.016 0" rpy="0 0 0"/>
  </joint>

  <joint name="gripper_base_to_gripper_right3" type="fixed">
    <parent link="gripper_base"/>
    <child link="gripper_right3"/>
    <origin xyz="0.012 0.005 0" rpy="0 0 0"/>
  </joint>

  <joint name="gripper_base_to_gripper_right2" type="fixed">
    <parent link="gripper_base"/>
    <child link="gripper_right2"/>
    <origin xyz="0.005 0.027 0" rpy="0 0 0"/>
  </joint>

  <joint name="gripper_right3_to_gripper_right1" type="fixed">
    <parent link="gripper_right3"/>
    <child link="gripper_right1"/>
    <origin xyz="0.027 0.016 0" rpy="0 0 0"/>
  </joint>

  </xacro:if>

</robot>
